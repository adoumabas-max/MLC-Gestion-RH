  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="dipe" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
  <parameter name="societe" class="java.lang.String"/><parameter name="periode" class="java.lang.String"/>
  <parameter name="pvidSal" class="java.lang.Long"/><parameter name="pvidPat" class="java.lang.Long"/>
  <parameter name="allocFam" class="java.lang.Long"/><parameter name="accident" class="java.lang.Long"/>
  <parameter name="total" class="java.lang.Long"/>
  <title><band height="50"><textField><reportElement x="0" y="0" width="555" height="22"/><textElement><font size="13" isBold="true"/></textElement>
    <textFieldExpression><![CDATA[$P{societe} + " — DIPE / Cotisations CNPS"]]></textFieldExpression></textField>
    <textField><reportElement x="0" y="26" width="555" height="16"/><textFieldExpression><![CDATA["Période : " + $P{periode}]]></textFieldExpression></textField></band></title>
  <detail><band height="120">
    <textField><reportElement x="0" y="0" width="555" height="18"/><textFieldExpression><![CDATA["PVID salarié : " + $P{pvidSal} + " FCFA"]]></textFieldExpression></textField>
    <textField><reportElement x="0" y="20" width="555" height="18"/><textFieldExpression><![CDATA["PVID employeur : " + $P{pvidPat} + " FCFA"]]></textFieldExpression></textField>
    <textField><reportElement x="0" y="40" width="555" height="18"/><textFieldExpression><![CDATA["Allocations familiales : " + $P{allocFam} + " FCFA"]]></textFieldExpression></textField>
    <textField><reportElement x="0" y="60" width="555" height="18"/><textFieldExpression><![CDATA["Accident du travail : " + $P{accident} + " FCFA"]]></textFieldExpression></textField>
    <textField><reportElement x="0" y="84" width="555" height="20"/><textElement><font size="12" isBold="true"/></textElement>
      <textFieldExpression><![CDATA["TOTAL CNPS : " + $P{total} + " FCFA"]]></textFieldExpression></textField>
  </band></detail>
  <pageFooter><band height="20"><textField><reportElement x="0" y="0" width="555" height="14"/><textElement textAlignment="Center"><font size="8"/></textElement>
    <textFieldExpression><![CDATA["MLC-RH-DIPE — Document interne SMQ — Mercure Logistics SARL"]]></textFieldExpression></textField></band></pageFooter>
